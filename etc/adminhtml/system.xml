<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">

    <system>
        <section id="payment">
            <group id="simpay_magento"
                   translate="label"
                   type="text"
                   sortOrder="350"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">

                <label>SimPay</label>

                <field id="active"
                       translate="label"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>

                <field id="title"
                       translate="label"
                       type="text"
                       sortOrder="20"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Title</label>
                    <validate>required-entry</validate>
                </field>

                <field id="service_id"
                       translate="label"
                       type="text"
                       sortOrder="30"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Service ID</label>
                    <comment>Online payments → Services → Details → Service ID</comment>
                </field>

                <field id="api_password"
                       translate="label"
                       type="obscure"
                       sortOrder="40"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>API password</label>
                    <comment>Customer account → API → Details → Password / Bearer Token</comment>
                </field>

                <field id="ipn_signature_key"
                       translate="label"
                       type="text"
                       sortOrder="50"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>IPN signature key</label>
                    <comment>Online payments → Services → Details → Settings → IPN signature key</comment>
                </field>

                <field id="ipn_check_ip"
                       translate="label"
                       type="select"
                       sortOrder="55"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>IPN check IP</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <comment>Enable IP validation for IPN callbacks</comment>
                </field>

                <field id="webhook_url"
                       translate="label"
                       type="note"
                       sortOrder="60"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Webhook url</label>
                    <frontend_model>SimPay\Magento\Block\Adminhtml\System\Config\WebhookUrl</frontend_model>
                    <comment>Set this URL in SimPay panel as webhook/notification URL</comment>
                </field>

            </group>
        </section>
    </system>
</config>